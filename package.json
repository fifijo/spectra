{
  "name": "spectra-test-automation",
  "version": "0.1.0",
  "description": "Full-spectrum test automation using AI agents with Playwright",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "spectra": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "specs",
    "docs",
    "playwright.config.ts",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:seed": "playwright test tests/e2e/seed.spec.ts",
    "report": "playwright show-report .spectra/output/reports",
    "spectra": "node dist/cli.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "playwright",
    "testing",
    "e2e",
    "automation",
    "ai-agents",
    "test-generation",
    "self-healing",
    "mcp"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.18.3",
  "peerDependencies": {
    "@playwright/test": ">=1.50.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": false
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.9",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fifijo/spectra.git"
  },
  "homepage": "https://github.com/fifijo/spectra#readme",
  "bugs": {
    "url": "https://github.com/fifijo/spectra/issues"
  }
}
